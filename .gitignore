# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Artifacts (regenerated; provenance kept in committed logs/reproducibility/*.json).
# Match at ANY depth so nested dirs like draft_advisor/artifacts/ are covered too.
**/artifacts/*.npz
**/artifacts/*.parquet
*.npz.tmp
# Figures and the rendered report ARE committed as deliverable content (they are the
# report's images); only large intermediate artifacts are ignored above.

# pip-freeze sidecars embed the editable-install absolute path (OS username); the freeze
# SHA-256 is recorded in the committed repro-log JSON and the env is pinned by uv.lock.
logs/reproducibility/env/

# OS
Thumbs.db
.DS_Store

# local clones of the dashboard repos (independent git repos, not submodules)
FIFA_pool_2026_dashboard/
Fifa-Stats-Hub/
# session tooling + scratch
.claude/
logs/_research_tmp/
